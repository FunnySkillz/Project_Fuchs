{
  "expo": {
    "name": "SteuerFuchs",
    "slug": "SteuerFuchs",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/SteuerFuchs_Icon.png",
    "scheme": "steuerfuchs",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#208AEF"
    },
    "ios": {
      "bundleIdentifier": "com.funnyskillz.steuerfuchs",
      "icon": "./assets/images/SteuerFuchs_Icon.png",
      "infoPlist": {
        "NSCameraUsageDescription": "SteuerFuchs uses the camera to capture receipt photos.",
        "NSPhotoLibraryUsageDescription": "SteuerFuchs lets you choose receipt images and files from your library.",
        "NSPhotoLibraryAddUsageDescription": "SteuerFuchs may save processed receipt images for export preparation.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.funnyskillz.steuerfuchs",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/SteuerFuchs_Icon.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-sharing",
      [
        "expo-image-picker",
        {
          "cameraPermission": "SteuerFuchs uses the camera to capture receipt photos.",
          "photosPermission": "SteuerFuchs needs access to your photos to attach receipt images."
        }
      ],
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e1f908b7-f0ce-4eef-9c5a-a0fb6cd4e1b2"
      }
    }
  }
}
