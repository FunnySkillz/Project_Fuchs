{
  "expo": {
    "name": "SteuerFuchs",
    "slug": "SteuerFuchs",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "icon": "./assets/images/SteuerFuchs_Icon.png",
    "scheme": "steuerfuchs",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/SteuerFuchs_Icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#208AEF"
    },
    "ios": {
      "bundleIdentifier": "com.funnyskillz.steuerfuchs",
      "icon": "./assets/images/SteuerFuchs_Icon.png",
      "infoPlist": {
        "NSCameraUsageDescription": "Use your camera to capture receipt photos for tax documentation.",
        "NSPhotoLibraryUsageDescription": "Allow access to photos/files so you can attach receipt images and PDFs.",
        "NSPhotoLibraryAddUsageDescription": "SteuerFuchs may save processed receipt images you choose to keep for exports.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.funnyskillz.steuerfuchs",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/SteuerFuchs_Icon.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/SteuerFuchs_Icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-sharing",
      [
        "expo-image-picker",
        {
          "cameraPermission": "Use your camera to capture receipt photos for your tax records.",
          "photosPermission": "Allow access to photos/files so you can attach receipt images or PDFs."
        }
      ],
      "expo-sqlite",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "updates": {
      "url": "https://u.expo.dev/e1f908b7-f0ce-4eef-9c5a-a0fb6cd4e1b2"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e1f908b7-f0ce-4eef-9c5a-a0fb6cd4e1b2"
      }
    }
  }
}
